{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git show *": "allow",
      "git *": "deny",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "head *": "allow",
      "cat *": "allow",
      "javap *": "allow",
      "sbt *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "cargo *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "wc *": "allow"
    },
    "read": "allow",
    "edit": {
      "*": "ask",
      "src/*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "grep": "allow"
  },
  "lsp": {
    "rust": {
      "command": ["rust-analyzer"],
      "env": {
        "RUST_LOG": "debug"
      }
    }
  }
}
